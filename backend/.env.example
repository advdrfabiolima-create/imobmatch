# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/imobmatch?schema=public"

# JWT
JWT_SECRET=sua_chave_secreta_jwt_muito_segura_aqui
JWT_EXPIRES_IN=7d

# AWS S3 / Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_S3_BUCKET=imobmatch-files

# Email (Brevo HTTP API — não usa SMTP, funciona em qualquer host)
BREVO_API_KEY=sua_api_key_do_brevo
SMTP_FROM_EMAIL=contato@useimobmatch.com.br

# Asaas (gateway de pagamento)
# ⚠️  PRODUÇÃO: mude ASAAS_SANDBOX para false antes de ir ao ar.
#     Com true, nenhuma cobrança real é gerada e o servidor logará um erro crítico no boot.
ASAAS_SANDBOX=true   # ALTERE PARA false EM PRODUÇÃO
ASAAS_API_KEY=sua_chave_api_asaas_aqui
# Token gerado no painel Asaas → Configurações → Integrações → Webhooks → "Gerar Token"
ASAAS_WEBHOOK_SECRET=cole_aqui_o_token_gerado_no_painel_asaas

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Sentry (monitoramento de erros)
SENTRY_DSN=
