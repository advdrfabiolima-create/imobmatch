// ImobMatch - Schema Prisma
// Banco de dados PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USUÁRIOS ====================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  phone        String?
  city         String?
  state        String?
  agency       String?
  creci        String?
  bio          String?
  avatarUrl    String?
  role         Role     @default(AGENT)
  plan         String   @default("free")
  isLifetime   Boolean  @default(false)
  isActive     Boolean  @default(true)
  isFirstLogin Boolean  @default(true)
  lastSeen     DateTime?
  resetToken   String?
  resetTokenExpiry DateTime?
  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?
  emailVerificationExpiry    DateTime?
  asaasCustomerId       String?
  cpfCnpj               String?
  personType            String   @default("PF")  // PF | PJ
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Ranking & Reputação
  score             Int      @default(0)
  partnershipsCount Int      @default(0)
  dealsClosedCount  Int      @default(0)

  // Relações
  properties        Property[]
  buyers            Buyer[]
  sentPartnerships  Partnership[] @relation("PartnershipRequester")
  receivedPartnerships Partnership[] @relation("PartnershipReceiver")
  sentMessages      Message[]     @relation("MessageSender")
  receivedMessages  Message[]     @relation("MessageReceiver")
  opportunities     Opportunity[]
  posts             Post[]
  subscription      Subscription?
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique   // SHA-256 hash do token real
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("refresh_tokens")
}

enum Role {
  AGENT
  ADMIN
}

// ==================== IMÓVEIS ====================

model Property {
  id           String        @id @default(uuid())
  title        String
  type         PropertyType
  status       PropertyStatus @default(AVAILABLE)
  price        Decimal       @db.Decimal(12, 2)
  city         String
  state        String
  neighborhood String?
  address      String?
  bedrooms     Int?
  bathrooms    Int?
  parkingSpots Int?
  areaM2       Decimal?      @db.Decimal(8, 2)
  description  String?       @db.Text
  photos       String[]      @default([])
  listingType  String        @default("SALE")  // SALE | RENT
  isPublic     Boolean       @default(true)
  slug         String?       @unique
  agentId      String
  agent        User          @relation(fields: [agentId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relações
  matches       Match[]
  partnerships  Partnership[]
  opportunities Opportunity[]

  @@map("properties")
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  COMMERCIAL
  RURAL
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
  INACTIVE
}

// ==================== COMPRADORES ====================

model Buyer {
  id                  String       @id @default(uuid())
  buyerName           String
  email               String?
  phone               String?
  desiredCity         String
  desiredState        String?
  desiredNeighborhood String?
  maxPrice            Decimal      @db.Decimal(12, 2)
  minPrice            Decimal?     @db.Decimal(12, 2)
  propertyType        PropertyType
  bedrooms            Int?
  notes               String?      @db.Text
  status              BuyerStatus  @default(ACTIVE)
  agentId             String
  agent               User         @relation(fields: [agentId], references: [id])
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relações
  matches             Match[]
  partnerships        Partnership[]

  @@map("buyers")
}

enum BuyerStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

// ==================== MATCHES ====================

model Match {
  id         String      @id @default(uuid())
  buyerId    String
  buyer      Buyer       @relation(fields: [buyerId], references: [id])
  propertyId String
  property   Property    @relation(fields: [propertyId], references: [id])
  score      Int         @default(0)
  status     MatchStatus @default(PENDING)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([buyerId, propertyId])
  @@map("matches")
}

enum MatchStatus {
  PENDING
  CONTACTED
  VISITED
  NEGOTIATING
  CLOSED
  REJECTED
}

// ==================== PARCERIAS ====================

model Partnership {
  id             String            @id @default(uuid())
  buyerId        String?
  buyer          Buyer?            @relation(fields: [buyerId], references: [id])
  propertyId     String
  property       Property          @relation(fields: [propertyId], references: [id])
  requesterId    String
  requester      User              @relation("PartnershipRequester", fields: [requesterId], references: [id])
  receiverId     String
  receiver       User              @relation("PartnershipReceiver", fields: [receiverId], references: [id])
  status         PartnershipStatus @default(PENDING)
  commissionSplit Decimal?         @db.Decimal(5, 2)
  message        String?
  requesterIp    String?
  receiverIp     String?
  agreementHash  String?
  acceptedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("partnerships")
}

enum PartnershipStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

// ==================== OPORTUNIDADES ====================

model Opportunity {
  id            String   @id @default(uuid())
  title         String
  propertyType  PropertyType
  priceNormal   Decimal  @db.Decimal(12, 2)
  priceUrgent   Decimal  @db.Decimal(12, 2)
  city          String
  neighborhood  String?
  description   String?  @db.Text
  acceptsOffer  Boolean  @default(false)
  status        String   @default("active")
  photoUrl      String?
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id])
  agentId       String
  agent         User     @relation(fields: [agentId], references: [id])
  createdAt     DateTime @default(now())

  @@map("opportunities")
}

// ==================== FEED SOCIAL ====================

model Post {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        PostType
  content     String   @db.Text
  referenceId String?
  createdAt   DateTime @default(now())

  @@map("posts")
}

enum PostType {
  client
  property
  partnership
  opportunity
}

// ==================== ASSINATURAS ====================

model Subscription {
  id                  String             @id @default(uuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id])
  asaasCustomerId     String
  asaasSubscriptionId String?
  plan                String
  status              SubscriptionStatus @default(PENDING)
  nextDueDate         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("subscriptions")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  OVERDUE
  CANCELLED
  INACTIVE
}

// ==================== ACESSO ANTECIPADO ====================

model EarlyAccessLead {
  id         String            @id @default(uuid())
  fullName   String
  email      String            @unique
  whatsapp   String?
  source     String            @default("facebook_group")
  status     EarlyAccessStatus @default(WAITING)
  invitedAt  DateTime?
  createdAt  DateTime          @default(now())

  @@map("early_access_leads")
}

enum EarlyAccessStatus {
  WAITING
  INVITED
  REGISTERED
}

// ==================== FEEDBACKS ====================

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  userName  String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("feedbacks")
}

// ==================== MENSAGENS ====================

model Message {
  id          String   @id @default(uuid())
  content     String   @db.Text
  messageType String   @default("TEXT")
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  isRead      Boolean  @default(false)
  replyToId   String?
  replyTo     Message?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[] @relation("MessageReplies")
  createdAt   DateTime @default(now())

  @@map("messages")
}
