// ImobMatch - Schema Prisma
// Banco de dados PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USUÁRIOS ====================

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  phone        String?
  city         String?
  state        String?
  agency       String?
  creci        String?
  bio          String?
  avatarUrl    String?
  role         Role     @default(AGENT)
  plan         String   @default("starter")
  isActive     Boolean  @default(true)
  isFirstLogin Boolean  @default(true)
  lastSeen     DateTime?
  resetToken   String?
  resetTokenExpiry DateTime?
  emailVerified         Boolean  @default(false)
  emailVerificationToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  properties        Property[]
  buyers            Buyer[]
  sentPartnerships  Partnership[] @relation("PartnershipRequester")
  receivedPartnerships Partnership[] @relation("PartnershipReceiver")
  sentMessages      Message[]     @relation("MessageSender")
  receivedMessages  Message[]     @relation("MessageReceiver")

  @@map("users")
}

enum Role {
  AGENT
  ADMIN
}

// ==================== IMÓVEIS ====================

model Property {
  id           String        @id @default(uuid())
  title        String
  type         PropertyType
  status       PropertyStatus @default(AVAILABLE)
  price        Decimal       @db.Decimal(12, 2)
  city         String
  state        String
  neighborhood String?
  address      String?
  bedrooms     Int?
  bathrooms    Int?
  parkingSpots Int?
  areaM2       Decimal?      @db.Decimal(8, 2)
  description  String?       @db.Text
  photos       String[]      @default([])
  isPublic     Boolean       @default(true)
  slug         String?       @unique
  agentId      String
  agent        User          @relation(fields: [agentId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relações
  matches      Match[]
  partnerships Partnership[]

  @@map("properties")
}

enum PropertyType {
  HOUSE
  APARTMENT
  LAND
  COMMERCIAL
  RURAL
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
  INACTIVE
}

// ==================== COMPRADORES ====================

model Buyer {
  id                  String       @id @default(uuid())
  buyerName           String
  email               String?
  phone               String?
  desiredCity         String
  desiredState        String?
  desiredNeighborhood String?
  maxPrice            Decimal      @db.Decimal(12, 2)
  minPrice            Decimal?     @db.Decimal(12, 2)
  propertyType        PropertyType
  bedrooms            Int?
  notes               String?      @db.Text
  status              BuyerStatus  @default(ACTIVE)
  agentId             String
  agent               User         @relation(fields: [agentId], references: [id])
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relações
  matches             Match[]

  @@map("buyers")
}

enum BuyerStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

// ==================== MATCHES ====================

model Match {
  id         String      @id @default(uuid())
  buyerId    String
  buyer      Buyer       @relation(fields: [buyerId], references: [id])
  propertyId String
  property   Property    @relation(fields: [propertyId], references: [id])
  score      Int         @default(0)
  status     MatchStatus @default(PENDING)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([buyerId, propertyId])
  @@map("matches")
}

enum MatchStatus {
  PENDING
  CONTACTED
  VISITED
  NEGOTIATING
  CLOSED
  REJECTED
}

// ==================== PARCERIAS ====================

model Partnership {
  id             String            @id @default(uuid())
  propertyId     String
  property       Property          @relation(fields: [propertyId], references: [id])
  requesterId    String
  requester      User              @relation("PartnershipRequester", fields: [requesterId], references: [id])
  receiverId     String
  receiver       User              @relation("PartnershipReceiver", fields: [receiverId], references: [id])
  status         PartnershipStatus @default(PENDING)
  commissionSplit Decimal?         @db.Decimal(5, 2)
  message        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("partnerships")
}

enum PartnershipStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

// ==================== MENSAGENS ====================

model Message {
  id          String   @id @default(uuid())
  content     String   @db.Text
  messageType String   @default("TEXT")
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id])
  receiverId  String
  receiver    User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  isRead      Boolean  @default(false)
  replyToId   String?
  replyTo     Message?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[] @relation("MessageReplies")
  createdAt   DateTime @default(now())

  @@map("messages")
}
