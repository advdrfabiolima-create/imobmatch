{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3001"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "node": "20.18.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.useimobmatch.com.br"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.useimobmatch.com.br"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
